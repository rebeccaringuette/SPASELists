    "@graph": [
        {
            "@id": "https://spase-group.org/data/model/spase-latest/spase-latest_xsd.htm#ConfidenceRating",
            "@type": "ConceptScheme",
            "title": "ConfidenceRating",
            "description": "Identifiers for the classification of the certainty of an assertion.",
            "creator": "Isabella Ruiz"
        },
        {
            "@type": "Concept",
            "prefLabel": "Probable",
            "definition": "Likely given the available evidence. Considered in the range of 4 to 7 on a scale of 0 to 10.",
            "inScheme": "https://spase-group.org/data/model/spase-latest/spase-latest_xsd.htm#ConfidenceRating"
        },
        {
            "@type": "Concept",
            "prefLabel": "Strong",
            "definition": "Highly likely given the available evidence. Considered in the range of 7 to 10 on a scale of 0 to 10.",
            "inScheme": "https://spase-group.org/data/model/spase-latest/spase-latest_xsd.htm#ConfidenceRating"
        },
        {
            "@type": "Concept",
            "prefLabel": "Unlikely",
            "definition": "Not likely given the available evidence. Considered equal to 0 on a scale of 0 to 10.",
            "inScheme": "https://spase-group.org/data/model/spase-latest/spase-latest_xsd.htm#ConfidenceRating"
        },      
         {
            "@type": "Concept",
            "prefLabel": "Weak",
            "definition": "Slightly likely given the available evidence. Considered in the range of 1 to 4 on a scale of 0 to 10.",
            "inScheme": "https://spase-group.org/data/model/spase-latest/spase-latest_xsd.htm#ConfidenceRating"
        } 
    ]
