      "@type": "Concept",
      "prefLabel": "ChargeExchange",
      "definition": "Chemical process involving a charge transfer from an ion (which becomes neutral) to a neutral (which becomes ionized).",
      "inScheme": "https://spase-group.org/data/model/spase-latest/skos/ProcessType"
    },
    {
      "@type": "Concept",
      "prefLabel": "DissociativeRecombination",
      "definition": "Chemical process by which an ion is neutralized by capturing an electron, and splits in two new neutral species.",
      "inScheme": "https://spase-group.org/data/model/spase-latest/skos/ProcessType"
    },
    {
      "@type": "Concept",
      "prefLabel": "ElectronImpact",
      "definition": "Chemical process by which a neutral is ionized thanks to the energy from the impact of an electron.",
      "inScheme": "https://spase-group.org/data/model/spase-latest/skos/ProcessType"
    },
    {
      "@type": "Concept",
      "prefLabel": "PhotoIonization",
      "definition": "Chemical process by which a neutral is ionized thanks to the energy from a photon.",
